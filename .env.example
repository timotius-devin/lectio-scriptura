# ─────────────────────────────────────────────────────────────────
# Lectio Scriptura — Environment Variables
# ─────────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your key below
#   3. NEVER commit .env to git — it is already in .gitignore
#
# WHERE TO GET YOUR KEY:
#   https://console.anthropic.com → API Keys → Create Key
#
# ─────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: restrict CORS to your production domain
# ALLOWED_ORIGIN=https://lectio.yourdomain.com
