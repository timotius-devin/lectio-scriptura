# Frontend environment variables
# Copy this to .env.local — Vite reads this automatically in dev mode.
# These are BUILD-TIME variables bundled into the JS.
#
# ⚠️  WARNING: Any variable prefixed with VITE_ is PUBLIC.
#     It will be visible in the compiled JS output.
#     NEVER put your ANTHROPIC_API_KEY here.
#
# Local dev:
#   Leave VITE_API_BASE_URL empty — the Vite dev proxy forwards
#   /api/* to the backend at localhost:8000 automatically.
#
# Production (separate Vercel + Fly.io setup):
#   Set VITE_API_BASE_URL to your Fly.io backend URL.
#   e.g. VITE_API_BASE_URL=https://lectio-scriptura.fly.dev

VITE_API_BASE_URL=
